# NODE ENVIRONMENT
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug

# FRONTEND CONFIG
NEXT_PUBLIC_APP_NAME=Mamiwata News
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_PRIMARY_COLOR=#1a7f3f
NEXT_PUBLIC_DARK_MODE_ENABLED=true

# BACKEND CONFIG
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
APP_NAME=Mamiwata News API
APP_VERSION=1.0.0

# DATABASE - MONGODB
MONGODB_URI=mongodb://admin:changeme@mongo:27017/mamiwata-news?authSource=admin
MONGODB_USER=admin
MONGODB_PASSWORD=changeme
MONGODB_POOL_SIZE=20
MONGODB_MAX_RETRIES=5

# REDIS CACHE
REDIS_URL=redis://:changeme@redis:6379
REDIS_PASSWORD=changeme
REDIS_DB=0
REDIS_TTL=3600

# JWT & SECURITY
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-prod
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-prod
JWT_REFRESH_EXPIRY=30d
JWT_ALGORITHM=HS256

# SESSION
SESSION_SECRET=your-session-secret-key-change-in-prod
BCRYPT_ROUNDS=12

# OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# EMAIL SERVICE
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@mamiwata-news.com
SENDGRID_FROM_NAME=Mamiwata News

# FILE STORAGE
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=mamiwata-news-uploads
AWS_S3_CDN_URL=https://cdn.mamiwata-news.com

# CORS & SECURITY
CORS_ORIGIN=http://localhost:3000,https://mamiwata-news.com
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# PAYMENTS - STRIPE
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CURRENCY=XOF

# ANALYTICS
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-id
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your-mixpanel-token

# LOCALIZATION
APP_LOCALE=fr_GN
TIMEZONE=Africa/Conakry
CURRENCY=XOF
SUPPORTED_LOCALES=fr,en
SUPPORTED_COUNTRIES=GN,SN,CI,ML,BJ,TG,NE,BF,GW

# FEATURES
FEATURE_COMMENTS_ENABLED=true
FEATURE_NEWSLETTERS=true
FEATURE_PREMIUM_CONTENT=false
FEATURE_LIVE_COVERAGE=true
FEATURE_ADS=true